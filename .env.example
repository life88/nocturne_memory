# =============================================================================
# Nocturne Memory — Configuration
# =============================================================================
# Run `python setup.py` for interactive setup, or edit manually below.
#
# The defaults below use ~/.nocturne-memory/ (the ~ is auto-expanded to your
# home directory — no manual absolute path needed).
# =============================================================================

# Database URL — SQLite (local) or PostgreSQL (remote/multi-device)
# ~ is automatically expanded to your home directory path.
# sqlite+aiosqlite:///~/.nocturne-memory/memory.db
# PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///~/.nocturne-memory/memory.db

# Valid memory domains (comma-separated)
# "system" is always available internally and does not need to be listed.
VALID_DOMAINS=core,writer,game,notes

# URIs to auto-load on system://boot (comma-separated)
# These are your AI's "core identity" memories, loaded every time it wakes up.
CORE_MEMORY_URIS=core://agent,core://my_user,core://agent/my_user

# ── Admin UI ─────────────────────────────────────────────────────────────────
# Port for the embedded web server (Dashboard + REST API).
WEB_PORT=8233

# Auto-open the Dashboard in browser when the server starts.
# Set to false to disable.
AUTO_OPEN_BROWSER=true

# Skip automatic frontend build on first startup.
# Set to true if you don't need the Dashboard or npm is not available.
SKIP_FRONTEND_BUILD=false

# ── Docker Compose ──────────────────────────────────────────────────────────
# POSTGRES_DB=nocturne_memory
# POSTGRES_USER=nocturne
# POSTGRES_PASSWORD=change_me_to_a_secure_password
# NGINX_PORT=80

# ── Authentication ──────────────────────────────────────────────────────────
# Leave commented out to disable authentication (local/single-user mode).
# Uncomment for production deployments exposed to the internet.
# API_TOKEN=change_me_to_a_secure_token
